## Database
## ─── Database Configuration ───
# Connection string format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fraud_db
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/test_fraud_db
POSTGRES_USER=finguard
POSTGRES_PASSWORD=f5c40ee5b135a96db40a7cf267104a39
POSTGRES_DB=finguard_db

## n8n Automation
N8N_WEBHOOK_URL=http://localhost:5678/webhook-test/fintech-fraud-alert

## JWT Security  ← Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=9a3f2c5d8e7b1a4f6c5d4e3b2a1f8e7d9c8b7a6f5e4d3c2b1a0f9e8d7c6b5a4

## CORS: comma-separated list of allowed frontend origins (NO wildcard in production!)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

## Environment: set to "production" for HSTS headers and stricter security
ENVIRONMENT=development

## External APIs
STRIPE_API_KEY=sk_test_...

## MLOps
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=finguard_fraud_detection
MLFLOW_MODEL_STAGE=production

## Redis / Velocity Engine
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
VELOCITY_WINDOW_MINUTES=5
VELOCITY_THRESHOLD=3

## Observability
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=d1e2f3c4b5a69788
LOG_LEVEL=INFO
LOG_FORMAT=json

## Email / SMTP
SMTP_SERVER=smtp.example.com
